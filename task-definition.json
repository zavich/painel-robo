{
  "family": "<TASK_FAMILY>",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },

  "executionRoleArn": "<EXECUTION_ROLE_ARN>",

  "containerDefinitions": [
    {
      "name": "painel-robo",
      "image": "<IMAGE_URI>",
      "essential": true,

      "portMappings": [
        {
          "containerPort": 3000,
          "hostPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "NODE_ENV",
          "value": "production"
        }
      ],
      "secrets": [
        {
          "name": "JWT_SECRET_KEY",
          "valueFrom": "<SECRET_ARN_PREFIX>:JWT_SECRET_KEY::"
        },
        {
          "name": "NEXT_API_KEY_MASTER",
          "valueFrom": "<SECRET_ARN_PREFIX>:NEXT_API_KEY_MASTER::"
        },
        {
          "name": "NEXT_PUBLIC_API_URL",
          "valueFrom": "<SECRET_ARN_PREFIX>:NEXT_PUBLIC_API_URL::"
        },
        {
          "name": "NEXT_PUBLIC_MAINTENANCE_MODE",
          "valueFrom": "<SECRET_ARN_PREFIX>:NEXT_PUBLIC_MAINTENANCE_MODE::"
        },
        {
          "name": "NEXT_PUBLIC_API_WS",
          "valueFrom": "<SECRET_ARN_PREFIX>:NEXT_PUBLIC_API_WS::"
        },
        {
          "name": "JWT_PUBLIC_KEY_ROBO_API",
          "valueFrom": "<SECRET_ARN_PREFIX>:JWT_PUBLIC_KEY_ROBO_API::"
        },
        {
          "name": "JWT_PUBLIC_KEY_JURI_API",
          "valueFrom": "<SECRET_ARN_PREFIX>:JWT_PUBLIC_KEY_JURI_API::"
        }
      ],

      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "<LOG_GROUP>",
          "awslogs-region": "<AWS_REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
